{
    "rust-analyzer.files.exclude": [
        "**/target/**",
        "**/node_modules/**",
        "**/.git/**",
        "**/.slint",
    ],
    "rust-analyzer.cargo.targetDir": "target",
    "rust-analyzer.check.extraArgs": ["--package", "oi-problem-tracker"],
    "rust-analyzer.check.command": "check",
}
